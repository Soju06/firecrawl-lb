{
  "version": "1.0",
  "skills": {
    "project-conventions": {
      "type": "domain",
      "enforcement": "remind",
      "priority": "high",
      "description": "Project code conventions (typing, structure, DI, testing, anti-patterns)",
      "promptTriggers": {
        "keywords": [
          "convention",
          "\ucee8\ubca4\uc158",
          "code architecture",
          "\ucf54\ub4dc \uc544\ud0a4\ud14d\ucc98",
          "coding standard"
        ],
        "intentPatterns": [
          "(implement|build|create|\uad6c\ud604|\uc0dd\uc131).*(module|feature|\ubaa8\ub4c8|\uae30\ub2a5)",
          "(convention|\ucee8\ubca4\uc158|architecture|\uc544\ud0a4\ud14d\ucc98).*(guide|reference|\ucc38\uc870)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/app/modules/**/*.py",
          "**/app/core/**/*.py",
          "**/app/db/**/*.py",
          "**/app/dependencies.py",
          "**/app/main.py",
          "**/tests/**/*.py"
        ],
        "pathExclusions": [
          "**/__pycache__/**"
        ]
      },
      "skipConditions": {
        "sessionSkillUsed": true,
        "envOverride": "SKIP_CONVENTION_GUARD"
      },
      "blockMessage": "BLOCKED: Run /project-conventions first.\nYou must review project conventions before editing code.\n\n\u2192 Skill tool: 'project-conventions'\n\u2192 Bypass: SKIP_CONVENTION_GUARD=1"
    }
  }
}
