# Database
FIRECRAWL_LB_DATABASE_URL=sqlite+aiosqlite:///~/.firecrawl-lb/store.db
# Optional PostgreSQL example (SQLite stays default if not set):
# FIRECRAWL_LB_DATABASE_URL=postgresql+asyncpg://firecrawl_lb:firecrawl_lb@127.0.0.1:5432/firecrawl_lb
FIRECRAWL_LB_DATABASE_MIGRATE_ON_STARTUP=true
FIRECRAWL_LB_DATABASE_SQLITE_PRE_MIGRATE_BACKUP_ENABLED=true
FIRECRAWL_LB_DATABASE_SQLITE_PRE_MIGRATE_BACKUP_MAX_FILES=5

# Timeouts (seconds)
FIRECRAWL_LB_UPSTREAM_CONNECT_TIMEOUT_SECONDS=30
FIRECRAWL_LB_PROXY_REQUEST_BUDGET_SECONDS=600
FIRECRAWL_LB_STREAM_IDLE_TIMEOUT_SECONDS=300
# https_proxy=
# http_proxy=
# all_proxy=

# Encryption key file (optional override; recommended for Docker volumes)
# FIRECRAWL_LB_ENCRYPTION_KEY_FILE=/var/lib/firecrawl-lb/encryption.key

# Upstream usage fetch
FIRECRAWL_LB_USAGE_FETCH_TIMEOUT_SECONDS=10
FIRECRAWL_LB_USAGE_FETCH_MAX_RETRIES=2
FIRECRAWL_LB_USAGE_REFRESH_ENABLED=true
FIRECRAWL_LB_USAGE_REFRESH_INTERVAL_SECONDS=60

# Firewall
# Trust X-Forwarded-For for firewall client IP detection (enable only behind trusted reverse proxy)
FIRECRAWL_LB_FIREWALL_TRUST_PROXY_HEADERS=false
# Comma-separated CIDR list for trusted proxy sources
FIRECRAWL_LB_FIREWALL_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Dashboard authentication mode:
# - standard: built-in password + optional TOTP (default)
# - trusted_header: trust a reverse proxy auth header from trusted proxy CIDRs; password/TOTP stay available as fallback and are still managed via fallback password sessions
# - disabled: bypass dashboard auth entirely (only use behind network restrictions or external auth); built-in password/TOTP management is off
FIRECRAWL_LB_DASHBOARD_AUTH_MODE=standard
# Header to trust in trusted_header mode (Authelia commonly forwards Remote-User)
FIRECRAWL_LB_DASHBOARD_AUTH_PROXY_HEADER=Remote-User
# Example trusted_header setup:
# FIRECRAWL_LB_DASHBOARD_AUTH_MODE=trusted_header
# FIRECRAWL_LB_FIREWALL_TRUST_PROXY_HEADERS=true
# FIRECRAWL_LB_FIREWALL_TRUSTED_PROXY_CIDRS=172.18.0.0/16
# FIRECRAWL_LB_DASHBOARD_AUTH_PROXY_HEADER=Remote-User
# Example hard bypass / Docker override:
# FIRECRAWL_LB_DASHBOARD_AUTH_MODE=disabled

# Production / Multi-Replica Settings
# Prometheus metrics (opt-in)
FIRECRAWL_LB_METRICS_ENABLED=false
FIRECRAWL_LB_METRICS_PORT=9090

# Logging format
FIRECRAWL_LB_LOG_FORMAT=text

# Leader election (opt-in)
FIRECRAWL_LB_LEADER_ELECTION_ENABLED=false
FIRECRAWL_LB_LEADER_ELECTION_TTL_SECONDS=30

# Circuit breaker (opt-in)
FIRECRAWL_LB_CIRCUIT_BREAKER_ENABLED=false
FIRECRAWL_LB_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
FIRECRAWL_LB_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60

# Backpressure (0 = unlimited)
FIRECRAWL_LB_BACKPRESSURE_MAX_CONCURRENT_REQUESTS=0

# OpenTelemetry (opt-in)
FIRECRAWL_LB_OTEL_ENABLED=false
FIRECRAWL_LB_OTEL_EXPORTER_ENDPOINT=

# Shutdown drain timeout
FIRECRAWL_LB_SHUTDOWN_DRAIN_TIMEOUT_SECONDS=30

# HTTP connector limits
FIRECRAWL_LB_HTTP_CONNECTOR_LIMIT=100
FIRECRAWL_LB_HTTP_CONNECTOR_LIMIT_PER_HOST=50

# Dashboard password/TOTP fallback is configured in the settings UI when dashboard auth mode allows it
